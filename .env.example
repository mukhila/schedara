APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Social OAuth ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI="${APP_URL}/auth/microsoft/callback"
MICROSOFT_TENANT_ID=common

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

# ── Social Integrations OAuth ──────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI="${APP_URL}/social/callback/linkedin"

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI="${APP_URL}/social/callback/twitter"

PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI="${APP_URL}/social/callback/pinterest"

THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
THREADS_REDIRECT_URI="${APP_URL}/social/callback/threads"

# Instagram Business shares FACEBOOK_CLIENT_ID / FACEBOOK_CLIENT_SECRET
INSTAGRAM_REDIRECT_URI="${APP_URL}/social/callback/instagram"

TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI="${APP_URL}/social/callback/tiktok"

# YouTube shares GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
YOUTUBE_REDIRECT_URI="${APP_URL}/social/callback/youtube"

# ── Billing ────────────────────────────────────────────────────────────
BILLING_DEFAULT_PROVIDER=stripe
APP_CURRENCY=USD

# Tax rates (0 = disabled; GST applies automatically when APP_CURRENCY=INR)
BILLING_TAX_RATE=0
BILLING_GST_RATE=18
BILLING_VAT_RATE=20
BILLING_INVOICE_PREFIX=INV

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_SANDBOX=true

# ── Media / CMS ────────────────────────────────────────────────────────
FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=schedara-media
AWS_ENDPOINT=                      # For S3-compatible services (MinIO, DigitalOcean Spaces)
AWS_USE_PATH_STYLE_ENDPOINT=false

# CloudFront CDN
CDN_BASE_URL=https://cdn.example.com
CDN_WARM_URL=                      # Optional: HTTP endpoint to warm cache on upload
CDN_INVALIDATION_URL=              # Optional: HTTP endpoint to purge CDN cache

# FFmpeg (required for video compression)
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
FFMPEG_THREADS=4

# Media processing limits
MEDIA_MAX_UPLOAD_MB=200
MEDIA_MAX_FILES_BATCH=10
MEDIA_IMAGE_QUALITY=85
MEDIA_THUMBNAIL_WIDTH=400
MEDIA_VIDEO_BITRATE=1500
MEDIA_VIDEO_TIMEOUT=3600

# Watermark
MEDIA_WATERMARK_TEXT=
MEDIA_WATERMARK_IMAGE=             # storage path to watermark overlay PNG

# Feature flags
MEDIA_AI_TAGGING=false
MEDIA_DETECT_DUPLICATES=true

# Queue names (used by Horizon supervisors)
MEDIA_QUEUE=media
MEDIA_IMAGE_QUEUE=image-optimization
MEDIA_VIDEO_QUEUE=video-compression
MEDIA_AI_QUEUE=media-ai

# ── AI Marketing Assistant ─────────────────────────────────────────────
# Provider API keys
OPENAI_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=

# Default provider: openai | claude | gemini
AI_DEFAULT_PROVIDER=openai

# Usage limits
AI_MONTHLY_TOKEN_LIMIT=100000

# Failover: automatically try next provider on failure
AI_FAILOVER_ENABLED=true

# Queue name for async AI jobs
AI_QUEUE_NAME=ai

# ── Queue / Horizon ────────────────────────────────────────────────────
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

HORIZON_PREFIX=schedara_horizon:
HORIZON_PATH=horizon

# ── Real-Time Broadcasting (Pusher) ────────────────────────────────────
BROADCAST_CONNECTION=pusher

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_SCHEME=https
PUSHER_HOST=

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ── Analytics ───────────────────────────────────────────────────────────
ANALYTICS_QUEUE=analytics
ANALYTICS_CACHE_TTL=300
ANALYTICS_VIRAL_THRESHOLD=5.0
ANALYTICS_ROI_ALERT_THRESHOLD=200.0
ANALYTICS_AI_ENABLED=false
ANALYTICS_SYNC_INTERVAL=60
ANALYTICS_REPORT_DISK=local
ANALYTICS_REPORT_PATH=analytics/reports
ANALYTICS_REPORT_EXPIRY_DAYS=7
ANALYTICS_LOG_RETENTION_DAYS=30

# Bitly URL shortening (optional — falls back to local /r/{shortCode} if not set)
BITLY_API_KEY=

# Platform API credentials (per-tenant via DB is preferred; these are global fallbacks)
GOOGLE_ANALYTICS_PROPERTY_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Notification Channels ──────────────────────────────────────────────
# Firebase Cloud Messaging (browser/mobile push)
FCM_PROJECT_ID=
FCM_SERVER_KEY=

# Twilio (SMS + WhatsApp)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+15550000000
TWILIO_WHATSAPP_FROM=+14155238886    # Twilio sandbox or approved sender

# Slack (default webhook; per-workspace stored in DB)
SLACK_DEFAULT_WEBHOOK_URL=

# Notification retention & queue
NOTIFICATION_RETENTION_DAYS=60
NOTIFICATION_DIGEST=weekly
NOTIFICATION_QUEUE=notifications

# ── Agency Client Management ───────────────────────────────────────────
# Primary SaaS domain (used for custom domain verification TXT records)
APP_DOMAIN=schedara.com

# Client report storage
CLIENT_REPORT_DISK=local
CLIENT_REPORT_PATH=client-reports

# White-label assets
WHITE_LABEL_DISK=public
WHITE_LABEL_PATH=white-label

# Report queue
REPORTS_QUEUE=reports

# Billing queue
BILLING_QUEUE=billing

# Client onboarding reminder delay (days after creation)
ONBOARDING_REMINDER_DAYS=3
